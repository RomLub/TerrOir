{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "crons": [
    {
      "path": "/api/cron/reminder-consumer",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/reminder-sms",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/order-timeout",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/review-followup",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/weekly-payout",
      "schedule": "0 8 * * 1"
    },
    {
      "path": "/api/cron/weekly-badges",
      "schedule": "0 9 * * 1"
    },
    {
      "path": "/api/cron/retry-failed-refunds",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/purge-stock-alerts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/purge-otp-codes",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/disputes-deadline-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/refund-expire-pending",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/cleanup-test-residuals",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron/leads-followups",
      "schedule": "0 7 * * *"
    }
  ],
  "functions": {
    "app/api/cron/order-timeout/route.tsx": { "maxDuration": 60 },
    "app/api/cron/reminder-consumer/route.tsx": { "maxDuration": 60 },
    "app/api/cron/reminder-sms/route.ts": { "maxDuration": 60 },
    "app/api/cron/review-followup/route.tsx": { "maxDuration": 60 },
    "app/api/cron/weekly-badges/route.ts": { "maxDuration": 120 },
    "app/api/cron/weekly-payout/route.tsx": { "maxDuration": 300 },
    "app/api/cron/retry-failed-refunds/route.ts": { "maxDuration": 60 },
    "app/api/cron/purge-stock-alerts/route.ts": { "maxDuration": 60 },
    "app/api/cron/purge-otp-codes/route.ts": { "maxDuration": 60 },
    "app/api/cron/disputes-deadline-check/route.tsx": { "maxDuration": 60 },
    "app/api/cron/refund-expire-pending/route.tsx": { "maxDuration": 60 },
    "app/api/cron/cleanup-test-residuals/route.ts": { "maxDuration": 60 },
    "app/api/cron/leads-followups/route.ts": { "maxDuration": 60 },
    "app/api/orders/[id]/cancel/route.tsx": { "maxDuration": 30 },
    "app/api/orders/[id]/confirm/route.tsx": { "maxDuration": 30 },
    "app/api/orders/[id]/complete/route.tsx": { "maxDuration": 30 }
  }
}
