# =============================================================================
# TerrOir — variables d'environnement
# =============================================================================
# Copie ce fichier en .env.local pour le dev, et déclare toutes ces variables
# dans Vercel (Production + Preview) avant de déployer.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
# Project URL + anon key : affichés côté client. Service role : serveur uniquement.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...replace...me
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...replace...me

# --- URLs applicatives ------------------------------------------------------
# Base de l'app consommateur (utilisée pour liens email, redirects Stripe).
# Inclure le sous-domaine `www.` pour rester aligné sur les cookies isolés
# (Chantier 4) et la valeur Vercel Production.
NEXT_PUBLIC_APP_URL=https://www.terroir-local.fr
# Sous-domaine producteur (onboarding Stripe Connect, invitations producteur)
NEXT_PUBLIC_PRODUCER_URL=https://pro.terroir-local.fr
# Sous-domaine admin (callbacks Supabase Auth admin : magic link, change
# email, reset password — cf. lib/auth/email-redirect.ts). Doit pointer sur
# le host admin pour préserver l'isolation cookies (Chantier 4).
NEXT_PUBLIC_ADMIN_URL=https://admin.terroir-local.fr

# --- Stripe -----------------------------------------------------------------
# Clés API : publishable côté client, secret côté serveur.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
# Signing secret du webhook (dashboard Stripe > Developers > Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Optionnel — force le mode attendu au boot (F-018). 'test' ou 'live'.
# Si non défini : VERCEL_ENV=production exige sk_live_*, sinon aucun check.
# Utile pour preview branches qui veulent fail-fast sur le mauvais secret.
# STRIPE_EXPECTED_MODE=test

# --- Mapbox -----------------------------------------------------------------
# Token de carte public (scope pk.). Utilisé sur /carte.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...replace...me

# --- Resend (emails transactionnels) ----------------------------------------
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=no-reply@terroir-local.fr
# Signing secret webhook entrant (dashboard Resend > Webhooks > endpoint).
# Format Svix : "whsec_<base64>". Utilisé par /api/webhooks/resend pour
# vérifier les events email.bounced / email.complained / email.delivered.
# Audit Email H-3 (2026-05-05).
RESEND_WEBHOOK_SECRET=whsec_replace_me

# --- Twilio (SMS rappels retrait) -------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=+15551234567
# Numéro mobile admin recevant les SMS critiques (cron disputes deadline check
# notamment). Format E.164 (+33XXXXXXXXX). Optionnel : si absent, l'alerte
# tombera back sur l'email ops uniquement.
TWILIO_ADMIN_PHONE=+33600000000

# --- Upstash (rate-limit Redis) ---------------------------------------------
# Helpers `lib/rate-limit.ts` (consumeRateLimit) — fail-open si absents :
# rate-limit désactivé silencieusement avec console.warn [RATE_LIMIT_WARN].
# REQUIS en prod (sécurité), tolérés en dev/preview.
# Crée un Redis Upstash gratuit (https://upstash.com), copie REST URL + token.
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_me

# --- Email change OTP HMAC (lib/email-change/hmac.ts) ----------------------
# Secret HMAC-SHA256 pour signer les OTP de changement d'email (lien dans le
# template email-change-otp-current/new). REQUIS au boot — throw si absent.
# Génère avec `openssl rand -hex 32`. Rotation = invalidation immédiate des
# OTP en vol (les users devront recommencer le flow).
EMAIL_CHANGE_OTP_SECRET=replace_with_openssl_rand_hex_32

# --- Cron secret ------------------------------------------------------------
# Valeur aléatoire forte : partagée entre vercel.json (header Authorization)
# et les handlers /api/cron/*. Génère avec `openssl rand -hex 32`.
CRON_SECRET=replace_with_openssl_rand_hex_32

# --- RGPD opt-out token -----------------------------------------------------
# HMAC-SHA256 secret utilisé par lib/rgpd/opt-out-token.ts pour générer les
# tokens déterministes des liens de désabonnement producer_interests
# (page /desabonnement). Rotation = invalidation de tous les liens déjà
# envoyés. Génère avec `openssl rand -hex 32`.
OPT_OUT_TOKEN_SECRET=replace_with_openssl_rand_hex_32

# --- Sentry (alerting + drift detection — Cluster B Phase 3, bugs-P1-3) ----
# DSN public exposé côté client par design (les events Sentry sont signés
# côté SDK + filtrés par projet Sentry).
NEXT_PUBLIC_SENTRY_DSN=https://your-project.ingest.sentry.io/abc123
# Auth token serveur uniquement (upload sourcemaps au build). Sans ce token,
# l'init Sentry reste fonctionnel (pas d'upload sourcemaps, errors brutes
# côté dashboard). Crée un token d'org Sentry avec scope project:write.
SENTRY_AUTH_TOKEN=replace_me
# Org + project Sentry (pour upload sourcemaps).
SENTRY_ORG=terroir
SENTRY_PROJECT=terroir-prod

# --- Ops alerting email (Cluster B Phase 3, bugs-P1-3) ---------------------
# Inbox technique recevant les alertes ops critiques (drift Stripe/DB,
# refund failed orphelins, webhook background errors). Distinct de
# SUPPORT_EMAIL (alertes business). Si non défini, fallback sur SUPPORT_EMAIL.
OPS_EMAIL=ops@terroir-local.fr

# --- Support email (alertes business — transfer.failed, dispute, payout) ---
# Inbox admin recevant les alertes business. Doit être déclaré pour le boot
# (lib/env/support-email.ts throw si absent).
SUPPORT_EMAIL=admin@terroir-local.fr
# Variante exposée côté client (pages publiques /contact). Optionnel —
# fallback sur "support@terroir-local.fr" hardcodé si absent.
NEXT_PUBLIC_SUPPORT_EMAIL=support@terroir-local.fr

# --- Refund threshold support (app/api/stripe/refund/route.tsx) ------------
# Seuil EUR au-delà duquel les refunds basculent en "support manuel" plutôt
# que automatique (alerte ops + flag review pré-exécution). Optionnel —
# défaut codé côté route. Ajuste si tu veux durcir/relâcher la limite.
SUPPORT_REFUND_THRESHOLD_EUR=200

# --- Role snapshot HMAC (T-321) ---------------------------------------------
# HMAC-SHA256 secret pour signer le cookie __Secure-terroir_role_snapshot
# (en dev / preview non-HTTPS : __terroir_role_snapshot legacy). Cache
# role lookup middleware, élimine 2 queries DB par request authentifiée :
# users.roles + admin_users). Dédié — pas de réutilisation OPT_OUT_TOKEN_SECRET
# (séparation des secrets, rotation indépendante). Rotation = invalidation
# immédiate de tous les snapshots existants (les users seront re-authentifiés
# via DB lookup au prochain hit middleware). Génère avec `openssl rand -hex 32`.
ROLE_SNAPSHOT_SECRET=replace_with_openssl_rand_hex_32
