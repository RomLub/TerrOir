# =============================================================================
# TerrOir — variables d'environnement
# =============================================================================
# Copie ce fichier en .env.local pour le dev, et déclare toutes ces variables
# dans Vercel (Production + Preview) avant de déployer.
# =============================================================================

# --- Supabase ---------------------------------------------------------------
# Project URL + anon key : affichés côté client. Service role : serveur uniquement.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...replace...me
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...replace...me

# --- URLs applicatives ------------------------------------------------------
# Base de l'app consommateur (utilisée pour liens email, redirects Stripe)
NEXT_PUBLIC_APP_URL=https://terroir-local.fr
# Sous-domaine producteur (onboarding Stripe Connect, invitations producteur)
NEXT_PUBLIC_PRODUCER_URL=https://pro.terroir-local.fr

# --- Stripe -----------------------------------------------------------------
# Clés API : publishable côté client, secret côté serveur.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
STRIPE_SECRET_KEY=sk_test_replace_me
# Signing secret du webhook (dashboard Stripe > Developers > Webhooks).
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# --- Mapbox -----------------------------------------------------------------
# Token de carte public (scope pk.). Utilisé sur /carte.
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1Ijoi...replace...me

# --- Resend (emails transactionnels) ----------------------------------------
RESEND_API_KEY=re_replace_me
RESEND_FROM_EMAIL=no-reply@terroir-local.fr

# --- Twilio (SMS rappels retrait) -------------------------------------------
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=replace_me
TWILIO_PHONE_NUMBER=+15551234567

# --- Cron secret ------------------------------------------------------------
# Valeur aléatoire forte : partagée entre vercel.json (header Authorization)
# et les handlers /api/cron/*. Génère avec `openssl rand -hex 32`.
CRON_SECRET=replace_with_openssl_rand_hex_32
